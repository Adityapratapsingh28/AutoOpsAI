    "/api/workflow/stream/{workflow_id}": {
      "get": {
        "tags": [
          "Workflows"
        ],
        "summary": "Stream Workflow",
        "description": "SSE endpoint for real-time workflow execution streaming.\n\nEvents streamed:\n  - status: Pipeline progress steps\n  - agents_designed: Agent configurations\n  - agent_executing: Agent started\n  - agent_completed: Agent finished\n  - final_output: Complete workflow result\n  - error: Execution error\n  - done: Stream complete",
        "operationId": "stream_workflow_api_workflow_stream__workflow_id__get",
        "parameters": [
          {
            "name": "workflow_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Workflow Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
